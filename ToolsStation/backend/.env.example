# OpenAI Configuration (Required)
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxx
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-3.5-turbo

# Feishu/Lark Configuration (Optional - for notifications)
FEISHU_WEBHOOK_URL=https://open.feishu.cn/open-apis/bot/v2/hook/xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# WeChat Configuration (Optional - for WeChat integration)
WECHAT_TOKEN=your_token_here
WECHAT_APPID=your_appid_here
WECHAT_SECRET=your_secret_here
WECHAT_AES_KEY=your_aes_key_here

# Database Configuration (Optional - defaults to sqlite:///./news.db)
DATABASE_URL=sqlite:///./news.db
